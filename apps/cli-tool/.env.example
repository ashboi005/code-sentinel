# CodeSentinel CLI Configuration
# Copy this file to .env and fill in your values

# Option 1: Use the built-in CodeSentinel proxy (default)
CODESENTINEL_PROXY_URL=https://codesentinel-proxy.example.com/v1
CODESENTINEL_PROXY_TOKEN=your-proxy-token-here

# Optional: Override scan-mode agent turns (default: 50)
# CODESENTINEL_OPENHARNESS_MAX_TURNS=50

# Optional: Override remediation-mode agent turns (default: 90)
# CODESENTINEL_REMEDIATION_MAX_TURNS=90

# Optional: Override allowed tools (comma-separated)
# CODESENTINEL_OPENHARNESS_ALLOWED_TOOLS=python,bash,read_file,grep,glob
